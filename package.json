{
  "name": "active-state",
  "version": "0.1.0",
  "description": "Tiny keyed pub/sub client store with a React hook for Next.js",
  "type": "module",
  "license": "MIT",
  "author": "Calvin Maighan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CalvinMaighan/active-state.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "./dist/react/index.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun test"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  }
}
